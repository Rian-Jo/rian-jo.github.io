---
import { getCollection } from 'astro:content';

import BaseLayout from '../../components/BaseLayout.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import { sortPublications } from '../../lib/publications';

const publications = sortPublications(await getCollection('publications'));
---

<BaseLayout title="Publications">
  <section class="section-block">
    <SectionTitle
      eyebrow="Publications"
      title="A cleaned and structured publication archive"
      summary="The publication list is rebuilt from the old BibTeX and PDF files, with explicit DOI, video, and file links instead of theme-generated placeholders."
    />
    <div class="grid-two">
      {
        publications.map((entry) => (
          <PublicationCard
            href={`/publications/${entry.data.slug}/`}
            title={entry.data.title}
            authors={entry.data.authors}
            venue={entry.data.venue}
            year={entry.data.year}
            keywords={entry.data.keywords}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>

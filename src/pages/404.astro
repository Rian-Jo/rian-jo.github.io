---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="404">
  <section class="redirect-shell">
    <p class="eyebrow">404</p>
    <h1>Page not found.</h1>
    <p class="lede">
      The old site structure has been removed. Use the main navigation to continue, or return to the
      homepage.
    </p>
    <div class="button-row">
      <a class="button button--primary" href="/">Go home</a>
      <a class="button" href="/writing/">Browse writing</a>
    </div>
  </section>
</BaseLayout>

---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<header class="section-title">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {summary && <p class="section-summary">{summary}</p>}
</header>
